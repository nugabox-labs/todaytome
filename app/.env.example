# Optional: copy to .env for local overrides only.
# Docker Compose sets PORT, DATABASE_URL, and TZ — app/.env is not required.

PORT=3927
DATABASE_URL=file:../../data/todaytome.db

# APNs (Apple Push Notification service)
# developer.apple.com → Certificates, IDs & Profiles → Keys
APNS_KEY_PATH=./certs/AuthKey_XXXXXXXXX.p8
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRODUCTION=false