generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  userId        String   @unique @map("user_id")
  platform      String?
  deviceName    String?  @map("device_name")
  icloudEnabled Boolean  @default(false) @map("icloud_enabled")
  // 실시간 말씀(Live Activity) 자동 표시 설정
  autoLiveActivity Boolean @default(true) @map("auto_live_activity")
  liveActivityTime String @default("00:00") @map("live_activity_time")
  // 말씀 등록 알림 설정
  reminderEnabled  Boolean @default(true) @map("reminder_enabled")
  reminderTime     String  @default("08:00") @map("reminder_time")
  // 기기 로컬 시간 계산을 위한 UTC offset(분). 기본 KST(+9h).
  tzOffsetMinutes  Int     @default(540) @map("tz_offset_minutes")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  bibleRecords BibleRecord[]
  devices      Device[]

  @@map("users")
}

model BibleRecord {
  id          Int      @id @default(autoincrement())
  recordId    String   @unique @map("record_id")
  userId      String   @map("user_id")
  subject     String
  bible       String
  translation String   @default("개역개정")
  recordDate  DateTime @map("record_date")
  source      String   @default("manual")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [userId])

  @@index([userId, recordDate], map: "idx_bible_records_user_date")
  @@index([userId, createdAt], map: "idx_bible_records_user_created")
  @@map("bible_records")
}

model Device {
  id                Int      @id @default(autoincrement())
  deviceId          String   @map("device_id")
  userId            String   @map("user_id")
  platform          String?
  deviceName        String?  @map("device_name")
  apnsToken         String?  @map("apns_token")
  pushToStartToken  String?  @map("push_to_start_token")
  activityPushToken String?  @map("activity_push_token")
  // "sandbox"(Xcode Debug) | "production"(TestFlight/App Store). null이면 APNS_PRODUCTION env로 폴백.
  apnsEnvironment   String?  @map("apns_environment")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [userId])

  @@unique([deviceId, userId], map: "uk_device_user")
  @@index([userId], map: "idx_devices_user_id")
  @@map("devices")
}

// Notion "Jesus Today" 데이터베이스에서 매시간 동기화되는 말씀 pool.
// 사용자가 그날 직접/랜덤 등록하지 않았을 때 결정론적 오늘의 말씀(dailyVerse)의 소스로 사용.
model NotionVerse {
  id           Int       @id @default(autoincrement())
  notionPageId String    @unique @map("notion_page_id")
  subject      String
  bible        String
  translation  String    @default("개역개정")
  sourceDate   DateTime? @map("source_date")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("notion_verses")
}
