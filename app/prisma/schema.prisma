generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  userId        String   @unique @map("user_id")
  platform      String?
  deviceName    String?  @map("device_name")
  icloudEnabled Boolean  @default(false) @map("icloud_enabled")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  bibleRecords BibleRecord[]
  devices      Device[]

  @@map("users")
}

model BibleRecord {
  id          Int      @id @default(autoincrement())
  recordId    String   @unique @map("record_id")
  userId      String   @map("user_id")
  subject     String
  bible       String
  translation String   @default("개역개정")
  recordDate  DateTime @map("record_date")
  source      String   @default("manual")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [userId])

  @@index([userId, recordDate], map: "idx_bible_records_user_date")
  @@index([userId, createdAt], map: "idx_bible_records_user_created")
  @@map("bible_records")
}

model Device {
  id                Int      @id @default(autoincrement())
  deviceId          String   @map("device_id")
  userId            String   @map("user_id")
  platform          String?
  deviceName        String?  @map("device_name")
  apnsToken         String?  @map("apns_token")
  pushToStartToken  String?  @map("push_to_start_token")
  activityPushToken String?  @map("activity_push_token")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [userId])

  @@unique([deviceId, userId], map: "uk_device_user")
  @@index([userId], map: "idx_devices_user_id")
  @@map("devices")
}
